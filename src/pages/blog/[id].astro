---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.date,
  "dateModified": post.data.updated || post.data.date,
  "author": {
    "@type": "Organization",
    "name": post.data.author,
  },
  "publisher": {
    "@type": "Organization",
    "name": "Kongsjorden Studio",
  },
};
---

<Layout title={post.data.title} description={post.data.description}>
  <article class="pt-28 pb-16 md:pt-36 md:pb-20">
    <div class="max-w-3xl mx-auto px-6">
      <!-- Back link -->
      <a href="/blog" class="inline-flex items-center gap-1.5 text-text-muted hover:text-primary text-sm font-medium mb-8 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Back to blog
      </a>

      <!-- Header -->
      <header class="mb-10">
        <div class="flex flex-wrap gap-2 mb-4">
          {post.data.tags.map((tag: string) => (
            <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-primary/10 text-primary">
              {tag}
            </span>
          ))}
        </div>
        <h1 class="font-display font-bold text-3xl md:text-4xl lg:text-5xl text-text mb-4 leading-tight">
          {post.data.title}
        </h1>
        <div class="flex items-center gap-4 text-text-dim text-sm">
          <time>
            {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          <span>by {post.data.author}</span>
        </div>
      </header>

      <!-- Content -->
      <div class="prose">
        <Content />
      </div>

      <!-- CTA -->
      <div class="mt-16 p-8 rounded-2xl bg-surface/50 border border-border/50 text-center">
        <h2 class="font-display font-bold text-2xl text-text mb-3">Try Simply Markdown</h2>
        <p class="text-text-muted mb-6">A beautiful native macOS viewer for all your Markdown files.</p>
        <a
          href="https://apps.apple.com/app/simply-markdown/id6760895817"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 bg-primary hover:bg-primary-hover text-white font-semibold rounded-xl transition-all duration-200 hover:scale-105"
        >
          Download on Mac App Store
        </a>
      </div>
    </div>
  </article>

  <!-- Blog post structured data -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</Layout>

<style>
  .font-display {
    font-family: 'Outfit', sans-serif;
  }

  .prose {
    color: var(--color-text-muted);
    line-height: 1.8;
  }

  .prose :global(h1) {
    color: var(--color-text);
    font-family: 'Outfit', sans-serif;
    font-weight: 700;
    font-size: 2rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .prose :global(h2) {
    color: var(--color-text);
    font-family: 'Outfit', sans-serif;
    font-weight: 700;
    font-size: 1.5rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .prose :global(h3) {
    color: var(--color-text);
    font-family: 'Outfit', sans-serif;
    font-weight: 600;
    font-size: 1.25rem;
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
  }

  .prose :global(p) {
    margin-bottom: 1.25rem;
  }

  .prose :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose :global(a:hover) {
    color: var(--color-primary-hover);
  }

  .prose :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  .prose :global(code) {
    background: var(--color-surface);
    padding: 0.15rem 0.4rem;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    font-family: var(--font-mono);
  }

  .prose :global(pre) {
    background: var(--color-surface) !important;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.875rem;
    line-height: 1.7;
  }

  .prose :global(ul) {
    list-style-type: disc;
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .prose :global(ol) {
    list-style-type: decimal;
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .prose :global(li) {
    margin-bottom: 0.375rem;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-primary);
    padding-left: 1rem;
    color: var(--color-text-dim);
    margin-bottom: 1.25rem;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
  }

  .prose :global(th) {
    background: var(--color-surface);
    color: var(--color-text);
    font-weight: 600;
    text-align: left;
    padding: 0.75rem;
    border: 1px solid var(--color-border);
  }

  .prose :global(td) {
    padding: 0.75rem;
    border: 1px solid var(--color-border);
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  .prose :global(img) {
    border-radius: 0.75rem;
    margin-bottom: 1.5rem;
  }
</style>
